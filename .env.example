# =========================================
# LaunchFlow Environment Variables Example
# Copy this file to .env and fill values
# =========================================

# App
NODE_ENV=development
PORT=5000

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/launchflow

# Better Auth
BETTER_AUTH_URL=http://localhost:5000
# In production with a Vercel frontend proxying /api to Render, set this to your Vercel app URL.
# Example: https://your-app.vercel.app
PUBLIC_AUTH_URL=
BETTER_AUTH_SECRET=replace_with_long_random_secret_key

# Optional comma-separated extra allowed frontend origins
CORS_ORIGINS=

# Redis
REDIS_URL=redis://localhost:6379

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# SMTP / Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_email_password_or_app_password

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=replace_me
AWS_SECRET_ACCESS_KEY=replace_me
AWS_BUCKET_NAME=launchflow-files

STRIPE_PRICE_PRO=price_1sampleProPriceId
STRIPE_PRICE_TEAM=price_1sampleTeamPriceId
STRIPE_PRICE_ENTERPRISE=price_1sampleEnterprisePriceId

# Logging
LOG_LEVEL=info
